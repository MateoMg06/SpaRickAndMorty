/* Cards */

.cards-section {
  padding: 18px;
  border: 1px solid var(--line);
  border-radius: 10px;
  background: linear-gradient(
    145deg,
    rgba(6, 17, 18, 0.92),
    rgba(2, 7, 8, 0.86)
  );
  box-shadow:
    inset 0 1px rgba(255, 255, 255, 0.03),
    0 18px 60px rgba(0, 0, 0, 0.35);
  backdrop-filter: blur(10px);
}

.section-label {
  display: flex;
  gap: 10px;
  align-items: center;
  margin-bottom: 14px;
  color: var(--green);
  font-family: "Share Tech Mono", monospace;
  font-size: 0.9rem;
  letter-spacing: 1px;
  text-transform: uppercase;
}

.section-label::after {
  flex: 1;
  height: 1px;
  content: "";
  background: linear-gradient(90deg, rgba(141, 255, 84, 0.55), transparent);
}

.card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(min(190px, 100%), 1fr));
  gap: 14px;
}

.card {
  position: relative;
  overflow: hidden;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: linear-gradient(
    145deg,
    rgba(6, 17, 18, 0.92),
    rgba(2, 7, 8, 0.86)
  );
  box-shadow:
    inset 0 1px rgba(255, 255, 255, 0.03),
    0 18px 60px rgba(0, 0, 0, 0.35);
  backdrop-filter: blur(10px);
  transition:
    border-color 0.18s ease,
    box-shadow 0.18s ease,
    transform 0.18s ease;
}

.card::before {
  position: absolute;
  top: 0;
  right: 16%;
  left: 16%;
  height: 1px;
  content: "";
  background: linear-gradient(
    90deg,
    transparent,
    rgba(141, 255, 84, 0.65),
    transparent
  );
  opacity: 0;
  transition: opacity 0.18s ease;
}

.card:hover {
  transform: translateY(-2px);
  border-color: rgba(141, 255, 84, 0.48);
  box-shadow: 0 0 22px rgba(141, 255, 84, 0.12);
}

.card:hover::before {
  opacity: 1;
}

.img-wrap {
  position: relative;
  aspect-ratio: 1;
  overflow: hidden;
  background: #020707;
}

.img-wrap::before {
  position: absolute;
  inset: 0;
  z-index: 0;
  content: "";
  background: #000;
}

.img-wrap img {
  position: relative;
  z-index: 1;
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  mix-blend-mode: screen;
}

.phosphor-over {
  position: absolute;
  inset: 0;
  z-index: 3;
  pointer-events: none;
  background: radial-gradient(
    ellipse at center,
    rgba(141, 255, 84, 0.08) 0%,
    transparent 70%
  );
}

.badge-id,
.badge-species,
.badge-gender {
  position: absolute;
  z-index: 5;
  font-family: "Share Tech Mono", monospace;
  font-size: 8px;
  letter-spacing: 1px;
  text-transform: uppercase;
}

.badge-id {
  top: 7px;
  left: 8px;
  color: rgba(141, 255, 84, 0.7);
}

.badge-species,
.badge-gender {
  padding: 2px 7px;
  border: 1px solid rgba(141, 255, 84, 0.28);
  border-radius: 999px;
  background: rgba(2, 9, 9, 0.82);
}

.badge-species {
  bottom: 7px;
  left: 7px;
  color: var(--green);
}

.badge-gender {
  top: 7px;
  right: 7px;
  color: var(--cyan);
}

.card-body {
  padding: 12px 13px 14px;
}

.card-name {
  margin-bottom: 8px;
  overflow: hidden;
  color: var(--text);
  font-size: 0.93rem;
  font-weight: 900;
  line-height: 1.1;
  text-overflow: ellipsis;
  text-transform: uppercase;
  white-space: nowrap;
}

.card-meta,
.card-loc {
  display: flex;
  gap: 6px;
  align-items: center;
  color: var(--muted);
  font-size: 0.76rem;
  line-height: 1.25;
  text-transform: uppercase;
}

.card-meta {
  margin-bottom: 6px;
}

.card-loc span {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.location-details,
.episode-details {
  display: grid;
  gap: 7px;
  margin-top: 10px;
}

.location-info,
.episode-info {
  display: grid;
  grid-template-columns: 18px auto minmax(0, 1fr);
  gap: 7px;
  align-items: center;
  min-height: 22px;
  overflow: hidden;
  color: var(--muted);
  font-size: 0.76rem;
  line-height: 1.25;
  text-transform: uppercase;
}

.info-value {
  overflow: hidden;
  color: var(--muted);
  text-overflow: ellipsis;
  white-space: nowrap;
}

.location-label,
.episode-label {
  color: var(--cyan);
  font-family: "Share Tech Mono", monospace;
  font-size: 0.66rem;
  font-weight: 900;
  letter-spacing: 1px;
}

.info-icon {
  position: relative;
  display: inline-block;
  width: 16px;
  height: 17px;
  flex: 0 0 16px;
}

.planet-icon {
  background-image: url("/assets/Img/planeta.png");
  background-position: center;
  background-repeat: no-repeat;
  background-size: contain;
  filter: drop-shadow(0 0 5px rgba(141, 255, 84, 0.42));
}

.portal-icon {
  border: 2px solid rgba(53, 245, 208, 0.86);
  border-radius: 50%;
  box-shadow:
    inset 0 0 5px rgba(141, 255, 84, 0.5),
    0 0 9px rgba(53, 245, 208, 0.24);
}

.portal-icon::before {
  position: absolute;
  inset: 3px;
  border: 1px solid rgba(141, 255, 84, 0.82);
  border-radius: 50%;
  content: "";
}

.calendar-icon {
  border: 1px solid rgba(53, 245, 208, 0.78);
  border-radius: 4px;
  box-shadow: 0 0 8px rgba(53, 245, 208, 0.14);
}

.calendar-icon::before {
  position: absolute;
  top: 3px;
  right: 2px;
  left: 2px;
  height: 1px;
  background: rgba(141, 255, 84, 0.82);
  content: "";
}

.calendar-icon::after {
  position: absolute;
  top: -2px;
  right: 3px;
  left: 3px;
  height: 4px;
  border-right: 1px solid rgba(53, 245, 208, 0.78);
  border-left: 1px solid rgba(53, 245, 208, 0.78);
  content: "";
}

.episode-icon {
  border: 1px solid rgba(141, 255, 84, 0.78);
  border-radius: 3px;
  box-shadow: 0 0 8px rgba(141, 255, 84, 0.14);
}

.episode-icon::before,
.episode-icon::after {
  position: absolute;
  right: 3px;
  left: 3px;
  height: 1px;
  background: rgba(53, 245, 208, 0.82);
  content: "";
}

.episode-icon::before {
  top: 5px;
}

.episode-icon::after {
  top: 9px;
}

.card-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8px;
  margin-top: 12px;
}

.edit-btn,
.delete-btn {
  min-height: 34px;
  padding: 0 9px;
  border: 1px solid rgba(141, 255, 84, 0.34);
  border-radius: 8px;
  color: var(--text);
  background: rgba(1, 13, 12, 0.82);
  font-family: "Share Tech Mono", monospace;
  font-size: 0.72rem;
  font-weight: 900;
  letter-spacing: 1px;
  text-transform: uppercase;
  cursor: pointer;
  transition:
    border-color 0.18s ease,
    background 0.18s ease,
    box-shadow 0.18s ease,
    transform 0.18s ease;
}

.edit-btn {
  color: var(--cyan);
  border-color: rgba(53, 245, 208, 0.42);
}

.delete-btn {
  color: var(--red);
  border-color: rgba(255, 75, 107, 0.42);
}

.edit-btn:hover {
  border-color: rgba(53, 245, 208, 0.78);
  background: rgba(8, 44, 42, 0.9);
  box-shadow: 0 0 14px rgba(53, 245, 208, 0.16);
  transform: translateY(-1px);
}

.delete-btn:hover {
  border-color: rgba(255, 75, 107, 0.78);
  background: rgba(52, 8, 18, 0.9);
  box-shadow: 0 0 14px rgba(255, 75, 107, 0.16);
  transform: translateY(-1px);
}

/* SweetAlert2 */

.swal2-container {
  z-index: 9999;
}

.rm-toast,
.rm-alert {
  border: 1px solid rgba(141, 255, 84, 0.42);
  color: var(--text);
  background:
    linear-gradient(145deg, rgba(3, 22, 23, 0.98), rgba(0, 8, 9, 0.96)),
    repeating-linear-gradient(
      0deg,
      rgba(141, 255, 84, 0.035) 0 1px,
      transparent 1px 5px
    );
  box-shadow:
    0 0 28px rgba(141, 255, 84, 0.16),
    0 18px 70px rgba(0, 0, 0, 0.55),
    inset 0 0 0 1px rgba(53, 245, 208, 0.08);
  font-family: var(--font-ui);
}

.rm-toast {
  padding: 12px 16px;
  clip-path: polygon(
    10px 0,
    calc(100% - 12px) 0,
    100% 12px,
    100% calc(100% - 12px),
    calc(100% - 10px) 100%,
    10px 100%,
    0 calc(100% - 10px),
    0 10px
  );
}

.rm-toast-title {
  color: var(--text);
  font-family: "Share Tech Mono", monospace;
  font-size: 0.9rem;
  letter-spacing: 0;
  text-transform: uppercase;
}

.rm-toast-progress {
  background: linear-gradient(90deg, var(--green), var(--cyan));
}

.rm-toast .swal2-success-ring {
  border-color: rgba(141, 255, 84, 0.38);
}

.rm-toast .swal2-success-line-tip,
.rm-toast .swal2-success-line-long {
  background-color: var(--green);
}

.rm-toast .swal2-x-mark-line-left,
.rm-toast .swal2-x-mark-line-right {
  background-color: var(--red);
}

.rm-alert {
  width: min(440px, calc(100vw - 32px));
  padding: 30px 28px 26px;
  border-radius: 10px;
}

.rm-alert::before,
.rm-alert::after {
  position: absolute;
  width: 24px;
  height: 24px;
  pointer-events: none;
  content: "";
}

.rm-alert::before {
  top: 12px;
  right: 12px;
  border-top: 1px solid rgba(141, 255, 84, 0.72);
  border-right: 1px solid rgba(141, 255, 84, 0.72);
}

.rm-alert::after {
  bottom: 12px;
  left: 12px;
  border-bottom: 1px solid rgba(53, 245, 208, 0.56);
  border-left: 1px solid rgba(53, 245, 208, 0.56);
}

.rm-alert-title {
  color: var(--green);
  font-family: Bangers, Impact, system-ui, sans-serif;
  font-size: clamp(2rem, 8vw, 2.7rem);
  font-weight: 400;
  letter-spacing: 1px;
  line-height: 0.95;
  text-shadow:
    0 0 18px rgba(141, 255, 84, 0.42),
    2px 2px 0 rgba(15, 65, 32, 0.9);
  text-transform: uppercase;
}

.rm-alert-text {
  color: rgba(241, 255, 244, 0.82);
  font-size: 1rem;
  line-height: 1.45;
}

.rm-alert-icon {
  border-color: rgba(255, 139, 61, 0.68);
  color: var(--orange);
  box-shadow: 0 0 22px rgba(255, 139, 61, 0.18);
}

.rm-alert-actions {
  gap: 12px;
  margin-top: 24px;
}

.rm-alert-confirm,
.rm-alert-cancel {
  min-height: 42px;
  padding: 0 18px;
  border: 1px solid rgba(141, 255, 84, 0.58);
  border-radius: 8px;
  color: var(--text);
  background: rgba(1, 13, 12, 0.9);
  font-family: "Share Tech Mono", monospace;
  font-size: 0.82rem;
  font-weight: 900;
  letter-spacing: 1px;
  text-transform: uppercase;
  cursor: pointer;
}

.rm-alert-confirm {
  border-color: rgba(255, 75, 107, 0.7);
  color: #fff;
  background: rgba(64, 10, 22, 0.9);
  box-shadow: 0 0 16px rgba(255, 75, 107, 0.16);
}

.rm-alert-cancel {
  color: var(--cyan);
  border-color: rgba(53, 245, 208, 0.58);
}

.rm-alert-confirm:hover {
  border-color: rgba(255, 75, 107, 1);
  background: rgba(92, 13, 30, 0.96);
}

.rm-alert-cancel:hover {
  border-color: rgba(53, 245, 208, 0.9);
  background: rgba(8, 44, 42, 0.92);
}

.status-dot {
  width: 7px;
  height: 7px;
  flex: 0 0 7px;
  border-radius: 50%;
}

.alive {
  background: var(--green);
  box-shadow:
    0 0 6px rgba(141, 255, 84, 0.95),
    0 0 14px rgba(57, 255, 136, 0.72);
}

.dead {
  background: var(--red);
  box-shadow:
    0 0 6px rgba(255, 75, 107, 0.9),
    0 0 12px rgba(255, 75, 107, 0.55);
}

.unknown-s {
  background: var(--muted);
  box-shadow: 0 0 8px rgba(145, 168, 154, 0.48);
}

@media (max-width: 900px) {
  .card-grid {
    grid-template-columns: repeat(auto-fill, minmax(min(160px, 100%), 1fr));
  }
}

@media (max-width: 640px) {
  .card-grid {
    grid-template-columns: 1fr;
  }

  .hero-copy p {
    max-width: 320px;
  }

  .stats-title {
    font-size: 1.18rem;
    line-height: 1.18;
  }
}

@media (max-width: 420px) {
  .hero-copy p {
    max-width: 300px;
    overflow-wrap: break-word;
  }

  .stats-title {
    font-size: 1.05rem;
  }

  .cards-section {
    padding: 12px;
  }

  .card-actions {
    grid-template-columns: 1fr;
  }

  .edit-btn,
  .delete-btn {
    min-height: 38px;
  }
}
